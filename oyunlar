<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>öğretmençocuk - Kelime Oyunu</title>
    <style>
        :root {
            --primary: #2980b9;
            --secondary: #e67e22;
            --success: #2ecc71;
            --danger: #e74c3c;
            --dark: #2c3e50;
            --bg: #f5f6fa;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg);
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        /* Ana Menü Ekranı */
        #menu-container {
            text-align: center;
            background: white;
            padding: 40px 50px;
            border-radius: 16px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
            border-top: 6px solid var(--secondary);
            max-width: 450px;
            width: 90%;
            transition: all 0.3s ease;
        }

        .brand-logo {
            font-size: 2.8rem;
            font-weight: bold;
            color: var(--secondary);
            margin: 0 0 10px 0;
        }

        .brand-logo span {
            color: var(--primary);
        }

        .brand-sub {
            font-size: 1.1rem;
            color: #7f8c8d;
            margin: 0 0 30px 0;
        }

        .play-btn {
            background: var(--primary);
            color: white;
            border: none;
            padding: 16px 40px;
            font-size: 1.3rem;
            font-weight: bold;
            border-radius: 30px;
            cursor: pointer;
            box-shadow: 0 5px 15px rgba(41, 128, 185, 0.3);
            transition: all 0.2s ease;
            width: 100%;
        }

        .play-btn:hover {
            background: #217dbb;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(41, 128, 185, 0.4);
        }

        /* Oyun Alanı Ekranı */
        #game-container {
            display: none;
            max-width: 900px;
            width: 95%;
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            border-top: 5px solid var(--primary);
            margin: 20px auto;
        }

        .game-header {
            text-align: center;
            margin-bottom: 20px;
        }

        .game-title {
            color: var(--dark);
            margin: 0 0 15px 0;
            font-size: 1.6rem;
            text-transform: uppercase;
            font-weight: 700;
        }

        .scoreboard {
            display: flex;
            justify-content: space-between;
            background: #edf2f7;
            padding: 12px 20px;
            border-radius: 8px;
            font-weight: bold;
            margin-bottom: 25px;
            color: var(--dark);
        }

        .game-board {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .column {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .column-title {
            text-align: center;
            font-weight: bold;
            color: var(--dark);
            background: #e2e8f0;
            padding: 10px;
            border-radius: 6px;
            margin-bottom: 5px;
            font-size: 1.1rem;
        }

        .card {
            background: #fff;
            border: 2px solid #cbd5e1;
            padding: 15px;
            text-align: center;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1.1rem;
            font-weight: 600;
            transition: all 0.2s ease;
            user-select: none;
        }

        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            border-color: var(--primary);
        }

        .card.selected-eng {
            background-color: #ebf8ff;
            border-color: var(--primary);
            color: var(--primary);
        }

        .card.selected-tr {
            background-color: #fffaf0;
            border-color: var(--secondary);
            color: var(--secondary);
        }

        .card.matched {
            background-color: #f0fff4;
            border-color: var(--success);
            color: var(--success);
            cursor: default;
            pointer-events: none;
            opacity: 0.6;
        }

        .card.wrong {
            background-color: #fff5f5;
            border-color: var(--danger);
            color: var(--danger);
            animation: shake 0.3s linear;
        }

        /* Sonuç Ekranı */
        #result-screen {
            display: none;
            text-align: center;
            background: white;
            padding: 40px;
            border-radius: 16px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            border-top: 6px solid var(--success);
            max-width: 500px;
            width: 90%;
        }

        .result-icon {
            font-size: 4rem;
            margin-bottom: 10px;
        }

        .result-title {
            font-size: 1.8rem;
            color: var(--dark);
            margin: 0 0 15px 0;
        }

        .stat-box {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            padding: 15px;
            border-radius: 8px;
            font-size: 1.2rem;
            margin-bottom: 25px;
            color: var(--dark);
        }

        .stat-line {
            margin: 8px 0;
        }

        .highlight-success {
            color: var(--success);
            font-weight: bold;
        }

        .highlight-danger {
            color: var(--danger);
            font-weight: bold;
        }

        .btn-restart {
            background: var(--secondary);
            color: white;
            border: none;
            padding: 12px 30px;
            font-size: 1.1rem;
            font-weight: bold;
            border-radius: 25px;
            cursor: pointer;
            transition: background 0.2s;
        }

        .btn-restart:hover {
            background: #d35400;
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            20%, 60% { transform: translateX(-6px); }
            40%, 80% { transform: translateX(6px); }
        }

        @media (max-width: 600px) {
            .game-board {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

    <div id="menu-container">
        <h1 class="brand-logo">öğretmen<span>çocuk</span></h1>
        <p class="brand-sub">Unit 10: Food and Drinks</p>
        <button class="play-btn" onclick="openGameInNewTabSimulation()">KELİME OYUNU 1</button>
    </div>

    <div id="game-container">
        <div class="game-header">
            <div style="font-size: 1.5rem; font-weight: bold; color: var(--secondary); margin-bottom: 5px;">öğretmençocuk</div>
            <h2 class="game-title">Unit 10: Kelime Eşleştirme Oyunu</h2>
        </div>
        
        <div class="scoreboard">
            <span id="score-text">Doğru Eşleşme: 0 / 10</span>
            <span id="status-text">Kelimeleri eşleştirmeye başlayın!</span>
        </div>

        <div class="game-board">
            <div class="column">
                <div class="column-title">English</div>
                <div id="english-container"></div>
            </div>
            <div class="column">
                <div class="column-title">Türkçe</div>
                <div id="turkish-container"></div>
            </div>
        </div>
    </div>

    <div id="result-screen">
        <div class="result-icon">🎉</div>
        <h2 class="result-title">Oyun Tamamlandı!</h2>
        <div class="stat-box">
            <div class="stat-line">Toplam Doğru Sayısı: <span id="final-correct" class="highlight-success">0</span></div>
            <div class="stat-line">Hatalı Tıklama Sayısı: <span id="final-wrong" class="highlight-danger">0</span></div>
            <div class="stat-line">Kazanılan Puan: <span id="final-score" style="font-weight: bold; color: var(--primary);">0</span></div>
        </div>
        <button class="btn-restart" onclick="backToMenu()">Ana Menüye Dön</button>
    </div>

    <script>
        // Görseldeki 30 kelimenin tamamı
        const wordPool = [
            { eng: "apple", tr: "elma" }, { eng: "orange", tr: "portakal" }, { eng: "lemon", tr: "limon" },
            { eng: "grapes", tr: "üzüm" }, { eng: "pear", tr: "armut" }, { eng: "apricot", tr: "kayısı" },
            { eng: "peach", tr: "şeftali" }, { eng: "watermelon", tr: "karpuz" }, { eng: "melon", tr: "kavun" },
            { eng: "plum", tr: "erik" }, { eng: "cherry", tr: "kiraz" }, { eng: "banana", tr: "muz" },
            { eng: "tomato", tr: "domates" }, { eng: "olives", tr: "zeytin" }, { eng: "butter", tr: "tereyağı" },
            { eng: "cheese", tr: "peynir" }, { eng: "honey", tr: "bal" }, { eng: "marmalade", tr: "marmelat" },
            { eng: "egg", tr: "yumurta" }, { eng: "bread", tr: "ekmek" }, { eng: "omelette", tr: "omlet" },
            { eng: "cereal", tr: "kahvaltılık gevrek" }, { eng: "toast", tr: "tost" }, { eng: "sandwich", tr: "sandviç" },
            { eng: "hamburger", tr: "hamburger" }, { eng: "pizza", tr: "pizza" }, { eng: "meatballs", tr: "köfte" },
            { eng: "meat", tr: "et" }, { eng: "chicken", tr: "tavuk" }, { eng: "fish", tr: "balık" }
        ];

        let selectedEngCard = null;
        let selectedTrCard = null;
        let correctCount = 0;
        let wrongCount = 0;
        let score = 0;
        const TOTAL_ROUNDS = 10; // Her oyunda ekrana gelecek rastgele kelime sayısı

        function shuffle(array) {
            return array.sort(() => Math.random() - 0.5);
        }

        function openGameInNewTabSimulation() {
            document.getElementById('menu-container').style.display = 'none';
            document.getElementById('result-screen').style.display = 'none';
            document.getElementById('game-container').style.display = 'block';
            initGame();
        }

        function initGame() {
            selectedEngCard = null;
            selectedTrCard = null;
            correctCount = 0;
            wrongCount = 0;
            score = 0;
            updateScoreboard();

            const currentWords = shuffle([...wordPool]).slice(0, TOTAL_ROUNDS);
            const engWords = shuffle([...currentWords]);
            const trWords = shuffle([...currentWords]);

            const engContainer = document.getElementById('english-container');
            const trContainer = document.getElementById('turkish-container');

            engContainer.innerHTML = '';
            trContainer.innerHTML = '';

            engWords.forEach(word => {
                const card = document.createElement('div');
                card.classList.add('card');
                card.innerText = word.eng;
                card.dataset.value = word.eng;
                card.onclick = () => selectCard(card, 'eng');
                engContainer.appendChild(card);
            });

            trWords.forEach(word => {
                const card = document.createElement('div');
                card.classList.add('card');
                card.innerText = word.tr;
                card.dataset.match = word.eng;
                card.onclick = () => selectCard(card, 'tr');
                trContainer.appendChild(card);
            });
        }

        function selectCard(card, type) {
            if (card.classList.contains('matched') || card.classList.contains('wrong')) return;

            if (type === 'eng') {
                if (selectedEngCard) selectedEngCard.classList.remove('selected-eng');
                selectedEngCard = card;
                card.classList.add('selected-eng');
            } else {
                if (selectedTrCard) selectedTrCard.classList.remove('selected-tr');
                selectedTrCard = card;
                card.classList.add('selected-tr');
            }

            checkMatch();
        }

        function checkMatch() {
            if (selectedEngCard && selectedTrCard) {
                const engValue = selectedEngCard.dataset.value;
                const trMatchValue = selectedTrCard.dataset.match;

                if (engValue === trMatchValue) {
                    selectedEngCard.className = 'card matched';
                    selectedTrCard.className = 'card matched';
                    correctCount++;
                    score += 10;
                    updateScoreboard();
                    document.getElementById('status-text').innerText = "Harika! Doğru eşleşme. 👏";

                    selectedEngCard = null;
                    selectedTrCard = null;

                    if (correctCount === TOTAL_ROUNDS) {
                        setTimeout(endGame, 800);
                    }
                } else {
                    const card1 = selectedEngCard;
                    const card2 = selectedTrCard;
                    
                    card1.classList.add('wrong');
                    card2.classList.add('wrong');
                    wrongCount++;
                    document.getElementById('status-text').innerText = "Yanlış eşleşme! Tekrar deneyin. ❌";

                    card1.classList.remove('selected-eng');
                    card2.classList.remove('selected-tr');
                    selectedEngCard = null;
                    selectedTrCard = null;

                    setTimeout(() => {
                        card1.classList.remove('wrong');
                        card2.classList.remove('wrong');
                    }, 400);
                }
            }
        }

        function updateScoreboard() {
            document.getElementById('score-text').innerText = `Doğru Eşleşme: ${correctCount} / ${TOTAL_ROUNDS}`;
        }

        function endGame() {
            document.getElementById('game-container').style.display = 'none';
            document.getElementById('result-screen').style.display = 'block';
            
            document.getElementById('final-correct').innerText = correctCount;
            document.getElementById('final-wrong').innerText = wrongCount;
            document.getElementById('final-score').innerText = score;
        }

        function backToMenu() {
            document.getElementById('result-screen').style.display = 'none';
            document.getElementById('menu-container').style.display = 'block';
        }
    </script>
</body>
</html>
